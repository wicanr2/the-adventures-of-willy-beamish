diff --git a/engines/dgds/autopilot.cpp b/engines/dgds/autopilot.cpp
new file mode 100644
index 00000000..9aaf057d
--- /dev/null
+++ b/engines/dgds/autopilot.cpp
@@ -0,0 +1,104 @@
+/* ScummVM dgds autopilot (ROTD CHT). See autopilot.h. */
+
+#include "common/file.h"
+#include "common/tokenizer.h"
+#include "common/debug.h"
+#include "dgds/autopilot.h"
+#include "dgds/dgds.h"
+#include "dgds/scene.h"
+
+namespace Dgds {
+
+bool Autopilot::load(const Common::String &path) {
+	Common::File f;
+	if (!f.open(Common::Path(path)))
+		return false;
+	while (!f.eos()) {
+		Common::String line = f.readLine();
+		line.trim();
+		if (line.empty() || line[0] == '#')
+			continue;
+		Common::StringTokenizer tok(line, " \t");
+		Common::String op = tok.nextToken();
+		Common::String a = tok.nextToken();
+		Common::String b = tok.nextToken();
+		Cmd c;
+		c.arg = a.empty() ? 0 : atoi(a.c_str());
+		c.arg2 = b.empty() ? 0 : atoi(b.c_str());
+		c.name = a;
+		if (op == "scene") c.op = 's';
+		else if (op == "use") c.op = 'u';
+		else if (op == "look") c.op = 'l';
+		else if (op == "dlg") c.op = 'd';
+		else if (op == "shot") c.op = 'p';
+		else if (op == "wait") c.op = 'w';
+		else if (op == "lang") c.op = 'g';
+		else if (op == "quit") c.op = 'q';
+		else continue;
+		_cmds.push_back(c);
+	}
+	_active = !_cmds.empty();
+	debug(1, "Autopilot: loaded %d commands from %s", (int)_cmds.size(), path.c_str());
+	return _active;
+}
+
+void Autopilot::tick(DgdsEngine *engine) {
+	if (!_active)
+		return;
+	if (_wait > 0) {
+		_wait--;
+		return;
+	}
+	if (_pc >= _cmds.size()) {
+		engine->quitGame();
+		return;
+	}
+	const Cmd &c = _cmds[_pc++];
+	switch (c.op) {
+	case 's': // scene N
+		engine->autopilotDismissIntro();
+		engine->changeScene(c.arg);
+		_wait = 30; // let the scene's enter ops / first frame settle
+		break;
+	case 'u': // use hotspot M
+		if (engine->getScene())
+			engine->getScene()->triggerHotAreaUse((uint16)c.arg);
+		_wait = 25; // let the dialogue render
+		break;
+	case 'l': // look at hotspot M (runs onLookOps -> description dialogue)
+		if (engine->getScene())
+			engine->getScene()->triggerHotAreaLook((uint16)c.arg);
+		_wait = 25;
+		break;
+	case 'd': // show dialog directly (QA gallery).
+		// "dlg <num>"        -> showDialog(0, num)        (Rise of the Dragon: scene-embedded)
+		// "dlg <file> <num>" -> showDialog(file, num)     (Willy Beamish: loads D<file>.DDS)
+		if (engine->getScene()) {
+			engine->getScene()->triggerHotAreaLook(0xffff); // clears lingering dialogs (no-op area)
+			if (c.arg2)
+				engine->getScene()->showDialog((uint16)c.arg, (uint16)c.arg2);
+			else
+				engine->getScene()->showDialog(0, (uint16)c.arg);
+		}
+		_wait = 25;
+		break;
+	case 'p': // screenshot
+		engine->saveShot(c.name);
+		_wait = 1;
+		break;
+	case 'g': // set display mode (0=Orig/EN 1=中文24 2=中文16 3=Deutsch)
+		engine->getCJK().setMode((DisplayMode)c.arg);
+		_wait = 3;
+		break;
+	case 'w':
+		_wait = c.arg;
+		break;
+	case 'q':
+		engine->quitGame();
+		break;
+	default:
+		break;
+	}
+}
+
+} // namespace Dgds
diff --git a/engines/dgds/autopilot.h b/engines/dgds/autopilot.h
new file mode 100644
index 00000000..48688be0
--- /dev/null
+++ b/engines/dgds/autopilot.h
@@ -0,0 +1,54 @@
+/* ScummVM dgds autopilot — a script-driven "special mode" for headless
+ * localization QA / game-testing. Non-upstream (ROTD CHT).
+ *
+ * Reusable pattern for ScummVM AVG localization projects: instead of driving
+ * the game from outside with synthetic mouse events (which fights the intro
+ * state machine), the engine reads a small text script and drives ITSELF —
+ * jumping scenes, invoking hotspot ops directly by number, and writing PNG
+ * screenshots of the final (post-scale, with CJK) framebuffer. This exercises
+ * every dialogue deterministically so the translated text can be reviewed.
+ *
+ * Enabled when an `autopilot.txt` script exists in the search path.
+ * Script commands (one per line):
+ *   scene <N>        jump to scene N (dismisses the intro menu)
+ *   use <M>          trigger hot-area M's onUse ops in the current scene
+ *   shot <name>      write autopilot_shots/<name>.png (640x400, crisp CJK)
+ *   wait <frames>    idle N frames (let a dialogue settle)
+ *   quit             end the run
+ */
+
+#ifndef DGDS_AUTOPILOT_H
+#define DGDS_AUTOPILOT_H
+
+#include "common/array.h"
+#include "common/str.h"
+
+namespace Dgds {
+
+class DgdsEngine;
+
+class Autopilot {
+public:
+	// Load the script if it exists; returns true and activates autopilot mode.
+	bool load(const Common::String &path);
+	bool isActive() const { return _active; }
+
+	// Called once per main-loop frame (after the frame is presented).
+	void tick(DgdsEngine *engine);
+
+private:
+	struct Cmd {
+		char op;            // 's'cene 'u'se 'p'hoto 'w'ait 'q'uit
+		int arg;
+		int arg2;           // second numeric arg, e.g. "dlg <file> <num>" (Willy DDS)
+		Common::String name;
+	};
+	Common::Array<Cmd> _cmds;
+	uint _pc = 0;
+	int _wait = 0;
+	bool _active = false;
+};
+
+} // namespace Dgds
+
+#endif
diff --git a/engines/dgds/cjk.cpp b/engines/dgds/cjk.cpp
new file mode 100644
index 00000000..7c7e3239
--- /dev/null
+++ b/engines/dgds/cjk.cpp
@@ -0,0 +1,342 @@
+/* ScummVM dgds CJK localization support (Rise of the Dragon CHT). Non-upstream. */
+
+#include "common/file.h"
+#include "common/debug.h"
+#include "dgds/cjk.h"
+#include "dgds/dgds.h"
+#include "dgds/font.h"
+
+namespace Dgds {
+
+int big5LinearIndex(byte lead, byte trail) {
+	int to;
+	if (trail >= 0x40 && trail <= 0x7E)
+		to = trail - 0x40;          // 0..62
+	else if (trail >= 0xA1 && trail <= 0xFE)
+		to = 63 + (trail - 0xA1);   // 63..156
+	else
+		return -1;
+	if (lead < 0x81 || lead > 0xFE)
+		return -1;
+	return (lead - 0x81) * 157 + to;
+}
+
+static inline bool isBig5Lead(byte b) { return b >= 0x81 && b <= 0xFE; }
+
+CJKSupport::CJKSupport()
+	: _loaded(false), _mode(kDispZH24), _w(0), _h(0), _bpr(0), _numGlyphs(0), _glyphs(nullptr) {}
+
+CJKSupport::~CJKSupport() { delete[] _font24.glyphs; delete[] _font16.glyphs; }
+
+bool CJKSupport::load() {
+	// Per-game asset prefix: Rise of the Dragon ships "dragon_*", Willy Beamish "beamish_*".
+	// The DTRN/DCJK formats are identical; only the font filenames differ.
+	const char *prefix = "dragon";
+	if (DgdsEngine::getInstance()->getGameId() == GID_WILLY)
+		prefix = "beamish";
+	loadFont(Common::String::format("%s_zh24.dcjk", prefix), _font24);
+	loadFont(Common::String::format("%s_zh16.dcjk", prefix), _font16);
+	loadTranslations("zh.dtr", _zh);
+	loadTranslations("de.dtr", _de); // optional German overlay (Latin, original font)
+
+	_avail.clear();
+	_avail.push_back(kDispOrig);
+	if (_font24.glyphs && !_zh.empty()) _avail.push_back(kDispZH24);
+	if (_font16.glyphs && !_zh.empty()) _avail.push_back(kDispZH16);
+	if (!_de.empty()) _avail.push_back(kDispDE);
+
+	_mode = (_font24.glyphs && !_zh.empty()) ? kDispZH24 : kDispOrig;
+	selectActiveFont();
+	_loaded = (_font24.glyphs != nullptr);
+	debug(1, "CJKSupport: zh=%d de=%d font24=%d font16=%d modes=%d",
+	      (int)_zh.size(), (int)_de.size(), _font24.glyphs != nullptr, _font16.glyphs != nullptr, (int)_avail.size());
+	return _loaded;
+}
+
+bool CJKSupport::loadFont(const Common::String &fontFile, BitmapFont &dst) {
+	Common::File f;
+	if (!f.open(Common::Path(fontFile))) {
+		warning("CJK: font %s not found", fontFile.c_str());
+		return false;
+	}
+	char magic[4];
+	f.read(magic, 4);
+	if (memcmp(magic, "DCJK", 4)) { warning("CJK: bad font magic"); return false; }
+	f.readByte();              // version
+	dst.w = f.readByte();
+	dst.h = f.readByte();
+	dst.bpr = f.readByte();
+	f.readByte();              // encoding
+	f.readByte(); f.readByte(); // pad
+	dst.num = f.readUint32LE();
+	uint32 bytes = dst.num * dst.bpr * dst.h;
+	dst.glyphs = new byte[bytes];
+	uint32 got = f.read(dst.glyphs, bytes);
+	if (got != bytes) {
+		warning("CJK: short font read %u/%u", got, bytes);
+		delete[] dst.glyphs; dst.glyphs = nullptr; return false;
+	}
+	debug(1, "CJK font %s %dx%d glyphs=%d", fontFile.c_str(), dst.w, dst.h, dst.num);
+	return true;
+}
+
+bool CJKSupport::loadTranslations(const Common::String &trnFile,
+                                  Common::HashMap<Common::String, Common::String> &dst) {
+	Common::File f;
+	if (!f.open(Common::Path(trnFile)))
+		return false;
+	char magic[4];
+	f.read(magic, 4);
+	if (memcmp(magic, "DTRN", 4)) { warning("CJK: bad trn magic"); return false; }
+	f.readByte(); f.readByte(); f.readByte(); f.readByte(); // version, lang, pad x2
+	uint32 count = f.readUint32LE();
+	for (uint32 i = 0; i < count; i++) {
+		uint16 klen = f.readUint16LE();
+		Common::String key;
+		for (uint16 k = 0; k < klen; k++) key += (char)f.readByte();
+		uint16 vlen = f.readUint16LE();
+		Common::String val;
+		for (uint16 v = 0; v < vlen; v++) val += (char)f.readByte();
+		dst[key] = val;
+	}
+	return true;
+}
+
+void CJKSupport::selectActiveFont() {
+	const BitmapFont &fnt = (_mode == kDispZH16) ? _font16 : _font24;
+	_w = fnt.w; _h = fnt.h; _bpr = fnt.bpr; _numGlyphs = fnt.num; _glyphs = fnt.glyphs;
+}
+
+void CJKSupport::cycleMode() {
+	if (_avail.empty()) return;
+	uint i = 0;
+	for (; i < _avail.size(); i++)
+		if (_avail[i] == _mode) break;
+	_mode = _avail[(i + 1) % _avail.size()];
+	selectActiveFont();
+	clearDeferredBg();
+}
+
+void CJKSupport::setLang(CJKLang l) {
+	_mode = (l == kCJKLangOrig) ? kDispOrig : kDispZH24;
+	selectActiveFont();
+	clearDeferredBg();
+}
+
+void CJKSupport::setMode(DisplayMode m) {
+	_mode = m;
+	selectActiveFont();
+	clearDeferredBg();
+}
+
+const char *CJKSupport::modeName() const {
+	switch (_mode) {
+	case kDispOrig: return "English";
+	case kDispZH24: return "Chinese 24";
+	case kDispZH16: return "Chinese 16";
+	case kDispDE:   return "Deutsch";
+	case kDispJA:   return "Japanese";
+	default:        return "?";
+	}
+}
+
+const Common::HashMap<Common::String, Common::String> &CJKSupport::activeOverlay() const {
+	return (_mode == kDispDE) ? _de : _zh;
+}
+
+const Common::String *CJKSupport::lookupDialog(int sceneNum, int dlgNum) const {
+	const Common::HashMap<Common::String, Common::String> &ov = activeOverlay();
+	Common::String key = Common::String::format("%d:%d", sceneNum, dlgNum);
+	if (!ov.contains(key))
+		return nullptr;
+	return &ov[key];
+}
+
+const Common::String *CJKSupport::lookupUI(const Common::String &englishSrc) const {
+	const Common::HashMap<Common::String, Common::String> &ov = activeOverlay();
+	Common::String s = englishSrc;
+	s.trim(); // normalize leading/trailing spaces (headers carry a leading space)
+	Common::String key = Common::String("UI:") + s;
+	if (!ov.contains(key))
+		return nullptr;
+	return &ov[key];
+}
+
+const byte *CJKSupport::glyphPtr(int idx) const {
+	if (idx < 0 || (uint32)idx >= _numGlyphs) return nullptr;
+	return _glyphs + (uint32)idx * _bpr * _h;
+}
+
+void CJKSupport::drawGlyph(Graphics::ManagedSurface *dst, int idx, int x, int y, uint32 color) const {
+	const byte *g = glyphPtr(idx);
+	if (!g) return;
+	byte *base = (byte *)dst->getBasePtr(0, 0);
+	int pitch = dst->pitch;
+	for (int ry = 0; ry < _h; ry++) {
+		int ty = y + ry;
+		if (ty < 0 || ty >= dst->h) continue;
+		const byte *row = g + ry * _bpr;
+		for (int cx = 0; cx < _w; cx++) {
+			int tx = x + cx;
+			if (tx < 0 || tx >= dst->w) continue;
+			if (row[cx >> 3] & (0x80 >> (cx & 7)))
+				base[ty * pitch + tx] = (byte)color;
+		}
+	}
+}
+
+int CJKSupport::stringWidth(const Common::String &s, const DgdsFont *asciiFont) const {
+	int w = 0;
+	uint i = 0;
+	while (i < s.size()) {
+		byte b = (byte)s[i];
+		if (isBig5Lead(b) && i + 1 < s.size() && big5LinearIndex(b, (byte)s[i + 1]) >= 0) {
+			w += _w / 2; i += 2; // layout in 320x200 space; font is 2x
+		} else {
+			if (b != '\r' && asciiFont) w += asciiFont->getCharWidth(b);
+			i += 1;
+		}
+	}
+	return w;
+}
+
+void CJKSupport::wrapText(const Common::String &s, int maxWidth,
+                          Common::StringArray &lines, const DgdsFont *asciiFont) const {
+	lines.clear();
+	Common::String cur;
+	int curw = 0;
+	uint i = 0;
+	while (i < s.size()) {
+		byte b = (byte)s[i];
+		if (b == '\r') {
+			lines.push_back(cur); cur.clear(); curw = 0; i += 1; continue;
+		}
+		Common::String unit;
+		int uw;
+		if (isBig5Lead(b) && i + 1 < s.size() && big5LinearIndex(b, (byte)s[i + 1]) >= 0) {
+			unit += (char)b; unit += s[i + 1]; uw = _w / 2; i += 2;
+		} else {
+			unit += (char)b; uw = asciiFont ? asciiFont->getCharWidth(b) : 6; i += 1;
+		}
+		if (maxWidth > 0 && curw + uw > maxWidth && !cur.empty()) {
+			lines.push_back(cur); cur.clear(); curw = 0;
+		}
+		cur += unit; curw += uw;
+	}
+	if (!cur.empty() || lines.empty())
+		lines.push_back(cur);
+}
+
+void CJKSupport::deferLine(int x, int y, int w, uint32 color, const Common::String &big5,
+                           Graphics::TextAlign align, const DgdsFont *asciiFont, bool persist) {
+	DeferredLine dl;
+	dl.text = big5; dl.x = x; dl.y = y; dl.w = w; dl.color = color;
+	dl.align = align; dl.asciiFont = asciiFont;
+	if (persist) {
+		dl.committed = false;
+		_deferredBg.push_back(dl);
+	} else {
+		_deferred.push_back(dl);
+	}
+}
+
+void CJKSupport::commitBg(const Common::Rect &rect) {
+	// A STORE AREA committed this rect of the screen: drop committed lines it overwrites (old
+	// content), and lock in the fresh lines inside it. Fresh lines outside the rect stay uncommitted
+	// (still drawn) -- this is what keeps the STORE-AREA-less subway map showing.
+	const int lineH = fontHeight() / 2 + 1; // CJK line height in 320x200 (deferLine coord) space
+	for (uint i = 0; i < _deferredBg.size();) {
+		DeferredLine &dl = _deferredBg[i];
+		bool overlaps = dl.x < rect.right && dl.x + dl.w > rect.left &&
+		                dl.y < rect.bottom && dl.y + lineH > rect.top;
+		if (overlaps) {
+			if (dl.committed) { _deferredBg.remove_at(i); continue; }
+			dl.committed = true;
+		}
+		i++;
+	}
+}
+
+void CJKSupport::clearDeferredBgRect(const Common::Rect &rect) {
+	const int lineH = fontHeight() / 2 + 1;
+	for (uint i = 0; i < _deferredBg.size();) {
+		const DeferredLine &dl = _deferredBg[i];
+		bool overlaps = dl.x < rect.right && dl.x + dl.w > rect.left &&
+		                dl.y < rect.bottom && dl.y + lineH > rect.top;
+		if (overlaps)
+			_deferredBg.remove_at(i);
+		else
+			i++;
+	}
+}
+
+// Draw a half-width ASCII glyph from the small game font, nearest-scaled 2x, so it
+// matches the 24px CJK height. Sentinel-keyed so the background shows through.
+static void drawAsciiScaled2x(Graphics::ManagedSurface *dst, const DgdsFont *font,
+                              byte ch, int x, int y, uint32 color) {
+	const byte SENT = 0xAB;
+	int aw = font->getCharWidth(ch), ah = font->getFontHeight();
+	if (aw <= 0 || ah <= 0) return;
+	Graphics::ManagedSurface tmp(aw + 1, ah + 1, dst->format);
+	tmp.fillRect(Common::Rect(aw + 1, ah + 1), SENT);
+	font->drawChar(&tmp, ch, 0, 0, color);
+	const int yoff = (24 - ah * 2) / 2;
+	const byte *tp = (const byte *)tmp.getBasePtr(0, 0);
+	byte *dp = (byte *)dst->getBasePtr(0, 0);
+	for (int yy = 0; yy < ah; yy++) {
+		for (int xx = 0; xx < aw; xx++) {
+			byte v = tp[yy * tmp.pitch + xx];
+			if (v == SENT) continue;
+			for (int dy = 0; dy < 2; dy++) {
+				int py = y + yoff + yy * 2 + dy;
+				if (py < 0 || py >= dst->h) continue;
+				byte *row = dp + py * dst->pitch;
+				for (int dx = 0; dx < 2; dx++) {
+					int px = x + xx * 2 + dx;
+					if (px >= 0 && px < dst->w) row[px] = (byte)v;
+				}
+			}
+		}
+	}
+}
+
+void CJKSupport::drawDeferredLine(Graphics::ManagedSurface *dst, const DeferredLine &dl) {
+	{
+		// Compute the left edge in 320x200 space (after alignment), then x2 to hi-res.
+		int swLayout = stringWidth(dl.text, dl.asciiFont);
+		int layoutX = dl.x;
+		if (dl.align == Graphics::kTextAlignCenter)
+			layoutX = dl.x + (dl.w - swLayout) / 2;
+		else if (dl.align == Graphics::kTextAlignRight)
+			layoutX = dl.x + (dl.w - swLayout);
+
+		int xcur = layoutX * 2;
+		const int y = dl.y * 2 + 2; // small downward nudge so CJK sits centered in bubbles/buttons
+		uint i = 0;
+		while (i < dl.text.size()) {
+			byte b = (byte)dl.text[i];
+			if (isBig5Lead(b) && i + 1 < dl.text.size()) {
+				int idx = big5LinearIndex(b, (byte)dl.text[i + 1]);
+				if (idx >= 0) {
+					drawGlyph(dst, idx, xcur, y, dl.color);
+					xcur += _w; i += 2; continue;
+				}
+			}
+			if (b != '\r' && dl.asciiFont) {
+				drawAsciiScaled2x(dst, dl.asciiFont, b, xcur, y, dl.color);
+				xcur += dl.asciiFont->getCharWidth(b) * 2;
+			}
+			i += 1;
+		}
+	}
+}
+
+void CJKSupport::flushDeferred(Graphics::ManagedSurface *dst) {
+	// Persistent TTM background text first, then per-frame dialogs/menus on top.
+	for (const DeferredLine &dl : _deferredBg)
+		drawDeferredLine(dst, dl);
+	for (const DeferredLine &dl : _deferred)
+		drawDeferredLine(dst, dl);
+}
+
+} // namespace Dgds
diff --git a/engines/dgds/cjk.h b/engines/dgds/cjk.h
new file mode 100644
index 00000000..0f1a3eb8
--- /dev/null
+++ b/engines/dgds/cjk.h
@@ -0,0 +1,120 @@
+/* ScummVM dgds CJK / multi-language localization support (Rise of the Dragon CHT).
+ * Non-upstream: engine-side translation overlays + bitmap fonts + display-mode cycle.
+ */
+
+#ifndef DGDS_CJK_H
+#define DGDS_CJK_H
+
+#include "common/str.h"
+#include "common/hashmap.h"
+#include "common/hash-str.h"
+#include "common/array.h"
+#include "graphics/managed_surface.h"
+#include "graphics/font.h"
+
+namespace Dgds {
+
+class DgdsFont;
+
+// Big5 linear index: (lead-0x81)*157 + trailoffset; matches tools/build_cjk_font.py
+int big5LinearIndex(byte lead, byte trail);
+
+// Display modes cycled with F8. CJK modes (ZH24/ZH16/JA) render the bitmap font via
+// the hi-res deferred path; DE substitutes Latin text drawn with the original game font.
+enum DisplayMode {
+	kDispOrig = 0,  // English (original) — overlay off
+	kDispZH24,      // 中文 24x24
+	kDispZH16,      // 中文 16x16
+	kDispDE,        // Deutsch (de overlay, original font)
+	kDispJA,        // 日本語 (reserved; needs ja.dtr + JP font)
+	kDispCount
+};
+
+// kept for the autopilot 'lang' command (0=orig, 1=中文24)
+enum CJKLang { kCJKLangOrig = 0, kCJKLangZH = 1, kCJKLangJA = 2 };
+
+class CJKSupport {
+public:
+	CJKSupport();
+	~CJKSupport();
+
+	// Load both bitmap fonts (24/16) + overlays (zh/de) from the search path.
+	bool load();
+	bool isLoaded() const { return _loaded; }
+
+	DisplayMode mode() const { return _mode; }
+	void setLang(CJKLang l); // autopilot compat: 0->Orig, 1->ZH24
+	void setMode(DisplayMode m); // set a specific mode (autopilot / config)

+
+void DgdsEngine::present2x() {
+	const byte *src = (const byte *)_vscreen.getPixels();
+	byte *dst = (byte *)_hiresBuffer.getPixels();
+	const int sp = _vscreen.pitch, dp = _hiresBuffer.pitch;
+	for (int y = 0; y < SCREEN_HEIGHT; y++) {
+		const byte *srow = src + y * sp;
+		byte *d0 = dst + (y * 2) * dp;
+		byte *d1 = d0 + dp;
+		for (int x = 0; x < SCREEN_WIDTH; x++) {
+			const byte v = srow[x];
+			d0[x * 2] = v; d0[x * 2 + 1] = v;
+			d1[x * 2] = v; d1[x * 2 + 1] = v;
+		}
+	}
+	_cjk.flushDeferred(&_hiresBuffer);
+	g_system->copyRectToScreen(_hiresBuffer.getPixels(), dp, 0, 0, SCREEN_WIDTH * 2, SCREEN_HEIGHT * 2);
+}

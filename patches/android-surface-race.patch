 	final protected EGLSurface initSurface() throws Exception {
+		// On fast devices and modern Android (15/16), the SurfaceView's underlying Surface can be
+		// transiently null/invalid during the Splash->ScummVM activity startup churn. Handing such a
+		// holder to eglCreateWindowSurface() throws UnsupportedOperationException ("... can only be
